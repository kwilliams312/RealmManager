# RealmManager Configuration
# Copy to .env and customize as needed.

# --- Database ---
DOCKER_DB_ROOT_PASSWORD=password
DOCKER_DB_EXTERNAL_PORT=3306

# --- Auth Server ---
# Docker image for the AzerothCore auth server.
# Change to a custom image if using a fork.
AC_AUTHSERVER_IMAGE=acore/ac-wotlk-authserver:master
DOCKER_AUTH_EXTERNAL_PORT=3724

# --- DB Import ---
# Docker image for initial database schema import.
AC_DB_IMPORT_IMAGE=acore/ac-wotlk-db-import:master

# --- Client Data ---
# Docker image for maps/vmaps/dbc data (shared across realms, pulled on first realm start).
# AC_CLIENT_DATA_IMAGE=acore/ac-wotlk-client-data:master

# --- WebUI ---
# Secret key for session encryption (must be >=32 chars in production!)
WEBUI_SECRET_KEY=realmmanager-default-secret-change-me-in-production!
DOCKER_WEBUI_EXTERNAL_PORT=5555

# --- Realm Data ---
# Host path for realm data (source checkouts, configs, logs).
# Defaults to ./data/realms relative to this directory.
# REALM_HOST_DIR=/absolute/path/to/realms

# --- Compose Project Name ---
# Used for volume and network naming. Change if running multiple instances.
# COMPOSE_PROJECT_NAME=realmmanager
